  parking_sites           parking_sites                @relation(fields: [site_id], references: [site_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subscription_vehicles_site")
  subscriptions           subscriptions                @relation(fields: [subscription_id], references: [subscription_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subscription_vehicles_subscription")
  vehicles                vehicles                     @relation(fields: [vehicle_id], references: [vehicle_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subscription_vehicles_vehicle")

  @@unique([subscription_id, vehicle_id], map: "uq_subscription_vehicle_link")
  @@index([site_id, plate_compact, status], map: "ix_subscription_vehicles_site_plate_status")
  @@index([site_id, status], map: "ix_subscription_vehicles_site_status")
  @@index([subscription_id, status], map: "ix_subscription_vehicles_subscription_status")
  @@index([vehicle_id, status], map: "ix_subscription_vehicles_vehicle_status")
}

model auth_login_attempts {
  attempt_key      String                          @id
  bucket_kind      auth_login_attempts_bucket_kind
  username         String                          @db.VarChar(64)
  ip_address       String?                         @db.VarChar(64)
  failure_count    Int                             @default(0)
  first_failure_at DateTime?                       @db.DateTime(0)
  last_failure_at  DateTime?                       @db.DateTime(0)
  lockout_until    DateTime?                       @db.DateTime(0)
  last_delay_ms    Int                             @default(0)
  created_at       DateTime                        @default(now()) @db.DateTime(0)
  updated_at       DateTime                        @default(now()) @db.DateTime(0)

  @@index([ip_address, updated_at], map: "ix_auth_login_attempts_ip")
  @@index([lockout_until, updated_at], map: "ix_auth_login_attempts_lockout")
  @@index([username, updated_at], map: "ix_auth_login_attempts_username")
}

model auth_user_sessions {
  session_id         String    @id @db.Char(36)
  user_id            BigInt
  role_code          String    @db.VarChar(32)
  access_token_hash  String    @unique(map: "uq_auth_user_sessions_access_hash") @db.Char(64)
  refresh_token_hash String    @unique(map: "uq_auth_user_sessions_refresh_hash") @db.Char(64)
  access_expires_at  DateTime  @db.DateTime(0)
  refresh_expires_at DateTime  @db.DateTime(0)
  last_seen_at       DateTime? @db.DateTime(0)
  last_refreshed_at  DateTime? @db.DateTime(0)
  revoked_at         DateTime? @db.DateTime(0)
  revoke_reason      String?   @db.VarChar(255)
  last_ip_address    String?   @db.VarChar(64)
  last_user_agent    String?   @db.VarChar(255)
  created_at         DateTime  @default(now()) @db.DateTime(0)
  updated_at         DateTime  @default(now()) @db.DateTime(0)
  users              users     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_auth_user_sessions_user")

  @@index([access_expires_at], map: "ix_auth_user_sessions_access_expiry")
  @@index([refresh_expires_at], map: "ix_auth_user_sessions_refresh_expiry")
  @@index([role_code, revoked_at], map: "ix_auth_user_sessions_role_revoked")
  @@index([user_id, created_at], map: "ix_auth_user_sessions_user_created")
}

