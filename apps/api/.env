# =============================
# Parkly API (recommended local dev baseline)
# Mục tiêu: demo ổn định + preview nhanh + tách rõ local OCR / fallback provider
# Ghi chú:
# - Các biến 'NEW_' hoặc ALPR_* nâng cao có thể cần wire thêm nếu code hiện tại chưa đọc.
# - Các biến còn lại giữ tương thích với .env hiện tại của bạn.
# =============================

NODE_ENV=development
LOG_LEVEL=info
TZ=Asia/Ho_Chi_Minh

# -------------------------------------------------
# API
# -------------------------------------------------
API_HOST=127.0.0.1
API_PORT=3000
API_PREFIX=/api

# Auth
API_AUTH_MODE=ON
API_ALLOW_QUERY_TOKEN=ON

API_ADMIN_TOKEN=admin_dev_token_change_me
API_OPS_TOKEN=ops_dev_token_change_me
API_GUARD_TOKEN=guard_dev_token_change_me
API_WORKER_TOKEN=worker_dev_token_change_me
API_CASHIER_TOKEN=cashier_dev_token_change_me

API_ADMIN_ACTOR_USER_ID=1
API_OPS_ACTOR_USER_ID=2
API_GUARD_ACTOR_USER_ID=3
API_WORKER_ACTOR_USER_ID=4
API_CASHIER_ACTOR_USER_ID=5

API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=60000

# -------------------------------------------------
# Upload / Media
# -------------------------------------------------
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_MAX_MB=8

# -------------------------------------------------
# ALPR Core
# -------------------------------------------------
ALPR_MODE=TESSERACT
ALPR_TESSERACT_BIN=C:\Program Files\Tesseract-OCR\tesseract.exe
ALPR_TESSERACT_LANG=eng+vie

# Local-first provider order. Chỉ đẩy cloud khi local chưa đủ chắc.
ALPR_PROVIDER_ORDER=TESSERACT
# Ví dụ khi cần fallback cloud:
# ALPR_PROVIDER_ORDER=TESSERACT,PLATE_RECOGNIZER

# Cloud / external provider (optional)
ALPR_PLATE_RECOGNIZER_TOKEN=
ALPR_OCRSPACE_API_KEY=
ALPR_HTTP_PROVIDER_URL=
ALPR_HTTP_PROVIDER_BEARER=

# -------------------------------------------------
# ALPR Performance / UX Tuning
# -------------------------------------------------
# PSM fast-path: chạy trước để phản hồi preview nhanh.
ALPR_FAST_PSM_MODES=7,6
# Deep-path: chỉ chạy khi fast-path chưa đủ chắc.
ALPR_SLOW_PSM_MODES=11

# TTL cache preview cùng ảnh để tránh OCR lại vô ích.
ALPR_PREVIEW_CACHE_TTL_MS=180000

# Timeout gợi ý cho local OCR.
ALPR_FAST_TIMEOUT_MS=2500
ALPR_DEEP_TIMEOUT_MS=6000

# Nếu code đã hỗ trợ phased preview thì dùng threshold này.
ALPR_FAST_ACCEPT_CONFIDENCE=0.86
ALPR_REVIEW_ACCEPT_CONFIDENCE=0.62

# Nếu code đã hỗ trợ pre-processing nâng cao.
ALPR_ENABLE_BINARY_VARIANTS=ON
ALPR_ENABLE_TWO_LINE_SPLIT=ON
ALPR_ENABLE_PLATE_REGION_DETECT=ON
ALPR_ENABLE_FILENAME_FALLBACK=OFF

# -------------------------------------------------
# Device capture auth / idempotency
# -------------------------------------------------
DEVICE_CAPTURE_AUTH_MODE=ON
DEVICE_CAPTURE_MAX_SKEW_SECONDS=300
DEVICE_CAPTURE_DEFAULT_SECRET=change_me_capture_secret
# DEVICE_CAPTURE_SECRETS_JSON={"GATE_01_ENTRY_CAMERA":"secret-camera-01","GATE_01_ENTRY_RFID":"secret-rfid-01"}
# DEVICE_CAPTURE_SECRET_GATE_01_ENTRY_CAMERA=secret-camera-01

# -------------------------------------------------
# Gate decision / anti-passback tuning
# -------------------------------------------------
GATE_DECISION_ANTI_PASSBACK_STALE_SECONDS=900
GATE_DECISION_ANTI_PASSBACK_SAME_LANE_DEBOUNCE_SECONDS=8

# OCR chưa chắc thì không hard block.
GATE_DECISION_OCR_REVIEW_REQUIRED_BELOW=0.70
GATE_DECISION_OCR_STRICT_VALID_ABOVE=0.88

# -------------------------------------------------
# MongoDB (logs / outbox demo)
# -------------------------------------------------
MONGO_URL=mongodb://localhost:27017
MONGO_DB=parking_logs

# -------------------------------------------------
# Outbox / worker
# -------------------------------------------------
OUTBOX_WORKER_INTERVAL_MS=3000
OUTBOX_INLINE_SYNC=false
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_BACKOFF_BASE_MS=5000
OUTBOX_BACKOFF_MAX_MS=300000
OUTBOX_BACKOFF_JITTER=true
OUTBOX_BATCH_SIZE=50
OUTBOX_LEASE_MS=120000

# -------------------------------------------------
# Demo overrides
# -------------------------------------------------
DEMO_SITE_CODE=SITE_DN_01
DEMO_DEVICE_CODE=GATE_01_ENTRY_CAMERA
PARKLY_APP_PROFILE=DEVLOG

# -------------------------------------------------
# App runtime DB (Prisma runtime => parking_app)
# -------------------------------------------------
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=parking_app
DATABASE_PASSWORD=AppPassword@123
DATABASE_NAME=parking_mgmt
DATABASE_URL=mysql://parking_app:AppPassword%40123@127.0.0.1:3306/parking_mgmt

# -------------------------------------------------
# Admin DB (Flyway / Prisma CLI / destructive scripts)
# -------------------------------------------------
DATABASE_ADMIN_HOST=127.0.0.1
DATABASE_ADMIN_PORT=3306
DATABASE_ADMIN_USER=parking_root
DATABASE_ADMIN_PASSWORD=RootPassword@123
DATABASE_ADMIN_NAME=parking_mgmt
DATABASE_URL_ADMIN=mysql://parking_root:RootPassword%40123@127.0.0.1:3306/parking_mgmt

# -------------------------------------------------
# Prisma / MariaDB pool tuning
# -------------------------------------------------
DB_POOL_LIMIT=5
DB_ACQUIRE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_S=300

# -------------------------------------------------
# Optional aliases for older scripts
# -------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=parking_app
MYSQL_PASSWORD=AppPassword@123
MYSQL_DB=parking_mgmt

# -------------------------------------------------
# Optional production-like serving
# -------------------------------------------------
SERVE_WEB=OFF
WEB_DIST_DIR=../web/dist
DB_RUNTIME_FALLBACK_TO_ADMIN=ON
DB_PREFER_LITERAL_LOCALHOST=OFF

# -------------------------------------------------
# Mobile QR pair helper
# -------------------------------------------------
# Admin helper page: http://localhost:3000/ui/mobile-pair.html
