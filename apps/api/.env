NODE_ENV=development
LOG_LEVEL=info
LOG_FORMAT=dev
LOG_REDACT_IP=OFF

# Core HTTP
API_HOST=0.0.0.0
API_PORT=3000
API_PREFIX=/api
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.84:5173

# Auth & access
API_AUTH_MODE=ON
API_ALLOW_QUERY_TOKEN=OFF
API_AUTH_ACCESS_TTL_MINUTES=15
API_AUTH_REFRESH_TTL_DAYS=7
API_AUTH_LOGIN_THROTTLE_WINDOW_SECONDS=300
API_AUTH_LOGIN_FAILURE_LOCKOUT_THRESHOLD=5
API_AUTH_LOGIN_LOCKOUT_SECONDS=120
API_AUTH_LOGIN_PROGRESSIVE_DELAY_MS=250
API_AUTH_LOGIN_PROGRESSIVE_DELAY_MAX_MS=1500
API_AUTH_SESSION_LIMIT_PER_USER=5
API_AUTH_SESSION_CLEANUP_EXPIRED_RETENTION_DAYS=3
API_AUTH_SESSION_CLEANUP_REVOKED_RETENTION_DAYS=30
API_AUTH_SESSION_CLEANUP_BATCH_LIMIT=500
API_AUTH_PASSWORD_MIN_LENGTH=10
API_AUTH_PASSWORD_REQUIRE_UPPERCASE=ON
API_AUTH_PASSWORD_REQUIRE_LOWERCASE=ON
API_AUTH_PASSWORD_REQUIRE_DIGIT=ON
API_AUTH_PASSWORD_REQUIRE_SPECIAL=ON
API_AUTH_BOOTSTRAP_PROFILE=DEMO
API_AUTH_DEMO_SEED_CREDENTIALS=ON
API_LEGACY_ROLE_TOKENS=OFF

# Internal service auth
API_INTERNAL_SERVICE_TOKEN=parkly_internal_token_local_2026
API_INTERNAL_SERVICE_TOKEN_ACTIVE=parkly_internal_token_local_2026
API_INTERNAL_SERVICE_TOKEN_NEXT=
API_INTERNAL_SERVICE_ROLE=WORKER

# legacy dev-only tokens (disabled by default when API_LEGACY_ROLE_TOKENS=OFF)
API_ADMIN_TOKEN=admin_dev_token_change_me
API_OPS_TOKEN=ops_dev_token_change_me
API_GUARD_TOKEN=guard_dev_token_change_me
API_WORKER_TOKEN=worker_dev_token_change_me
API_CASHIER_TOKEN=cashier_dev_token_change_me
API_ADMIN_ACTOR_USER_ID=1
API_OPS_ACTOR_USER_ID=2
API_GUARD_ACTOR_USER_ID=3
API_WORKER_ACTOR_USER_ID=4
API_CASHIER_ACTOR_USER_ID=5

# Rate limit
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_BACKEND=REDIS
API_RATE_LIMIT_PREFIX=parkly:api:rate-limit

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=parkly:development
REDIS_DB=0
REDIS_REQUIRED=ON
REDIS_TLS=OFF

# Database runtime
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=parking_app
DATABASE_PASSWORD=AppPassword@123
DATABASE_NAME=parking_mgmt
DATABASE_URL=mysql://parking_app:AppPassword%40123@127.0.0.1:3306/parking_mgmt

# Database admin
DATABASE_ADMIN_HOST=127.0.0.1
DATABASE_ADMIN_PORT=3306
DATABASE_ADMIN_USER=parking_root
DATABASE_ADMIN_PASSWORD=RootPassword@123
DATABASE_ADMIN_NAME=parking_mgmt
DATABASE_URL_ADMIN=mysql://parking_root:RootPassword%40123@127.0.0.1:3306/parking_mgmt

# DB connection
DB_POOL_LIMIT=5
DB_ACQUIRE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_S=300
DB_RUNTIME_FALLBACK_TO_ADMIN=OFF
DB_PREFER_LITERAL_LOCALHOST=OFF

# Legacy DB aliases
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=parking_app
MYSQL_PASSWORD=AppPassword@123
MYSQL_DB=parking_mgmt

# Object storage
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_MEDIA=parkly-media
S3_FORCE_PATH_STYLE=ON
S3_USE_SSL=OFF

# Media
MEDIA_STORAGE_DRIVER=MINIO
MEDIA_PRESIGN_TTL_SEC=300
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_MAX_MB=5

# OCR / ALPR
ALPR_MODE=TESSERACT
ALPR_TESSERACT_BIN=tesseract
ALPR_PROVIDER_ORDER=LOCAL,HTTP
ALPR_FAST_PSM_MODES=7,6
ALPR_DEEP_PSM_MODES=11,13
ALPR_FAST_TIMEOUT_MS=2500
ALPR_DEEP_TIMEOUT_MS=6000
ALPR_PREVIEW_MAX_CANDIDATES=5
ALPR_EXTERNAL_ESCALATION_THRESHOLD=86

# Capture security
DEVICE_CAPTURE_AUTH_MODE=ON
DEVICE_CAPTURE_MAX_SKEW_SECONDS=300
DEVICE_CAPTURE_DEFAULT_SECRET=parkly_default_device_secret_local_2026
DEVICE_CAPTURE_SECRET_ACTIVE=parkly_default_device_secret_local_2026
DEVICE_CAPTURE_SECRET_NEXT=
DEVICE_CAPTURE_SECRET_GATE_01_ENTRY_CAMERA=secret-camera-01
DEVICE_CAPTURE_SECRET_GATE_01_ENTRY_RFID=secret-rfid-01
DEVICE_CAPTURE_SECRET_GATE_01_EXIT_CAMERA=secret-camera-02
DEVICE_CAPTURE_SECRET_GATE_01_EXIT_RFID=secret-rfid-02

# Preview cache
PREVIEW_CACHE_BACKEND=REDIS
PREVIEW_CACHE_DEDUPE_TTL_MS=3000
PREVIEW_CACHE_RESPONSE_TTL_MS=2000
PREVIEW_CACHE_POLL_INTERVAL_MS=120
PREVIEW_CACHE_DEBUG_HEADERS=OFF

# Async / outbox
OUTBOX_WORKER_INTERVAL_MS=5000
OUTBOX_INLINE_SYNC=false
OUTBOX_MAX_ATTEMPTS=8
OUTBOX_BACKOFF_BASE_MS=5000
OUTBOX_BACKOFF_MAX_MS=300000
OUTBOX_BACKOFF_JITTER=true
OUTBOX_BATCH_SIZE=50
OUTBOX_LEASE_MS=120000

# Internal services
INTERNAL_PRESENCE_API_KEY=zone_intake_dev_key
INTERNAL_PRESENCE_HMAC_SECRET=zone_intake_dev_secret
INTERNAL_PRESENCE_SCHEMA_VERSION=zone.presence.v1
INTERNAL_PRESENCE_MAX_SKEW_SECONDS=300
INTERNAL_PRESENCE_STREAM_KEY=parkly:development:internal-presence-events

# Decision / reconciliation
DECISION_ENABLE_SUBSCRIPTIONS=ON
RECONCILIATION_SENSOR_STALE_SECONDS=180

# Deployment profiles / compose packaging
PARKLY_DEPLOYMENT_PROFILE=RELEASE_CANDIDATE
PARKLY_MEDIA_PROFILE=MINIO
PARKLY_ALLOW_MEDIA_OVERRIDE=OFF
COMPOSE_PROJECT_NAME=parkly
MYSQL_ROOT_PASSWORD=RootPassword@123
COMPOSE_MYSQL_PORT=3306
COMPOSE_REDIS_PORT=6379
COMPOSE_MINIO_API_PORT=9000
COMPOSE_MINIO_CONSOLE_PORT=9001
DEPLOYMENT_VERIFY_TIMEOUT_MS=800
DEPLOYMENT_VERIFY_RETRIES=12
DEPLOYMENT_VERIFY_RETRY_DELAY_MS=1000

# Demo / local platform
DEMO_SITE_CODE=SITE_HCM_01
DEMO_DEVICE_CODE=GATE_01_ENTRY_CAMERA
PARKLY_APP_PROFILE=MVP
SERVE_WEB=OFF
WEB_DIST_DIR=../web/dist

# Supporting services
MONGO_URL=mongodb://localhost:27017
MONGO_DB=parking_logs

# Smoke / release hardening
SMOKE_USERNAME=ops
SMOKE_PASSWORD=Parkly@123
SMOKE_ROLE=OPS
SMOKE_SITE_CODE=SITE_HCM_01
SMOKE_ZONE_CODE=VIP_A
SMOKE_SPOT_CODE=HCM-VIP-01
SMOKE_MISMATCH_PLATE=51B67890
SMOKE_REQUIRE_INCIDENT=ON
SMOKE_RESOLVE_ACTION=RESOLVED
SMOKE_MEDIA_DRIVER=MINIO

# Retention / cleanup automation
RETENTION_PROFILE=DEMO
RETENTION_PRESERVE_DEMO_SEED=ON
RETENTION_CLEANUP_BATCH_LIMIT=250
RETENTION_AUTH_LOGIN_ATTEMPTS_RETENTION_DAYS=14
RETENTION_INCIDENT_NOISE_HISTORY_RETENTION_DAYS=30
RETENTION_INTERNAL_PRESENCE_REJECTED_RETENTION_DAYS=14
RETENTION_INTERNAL_PRESENCE_ACCEPTED_RETENTION_DAYS=
RETENTION_SMOKE_ARTIFACT_RETENTION_DAYS=21
RETENTION_TEMP_UPLOAD_RETENTION_HOURS=24
RETENTION_RUNTIME_ARTIFACT_RETENTION_DAYS=14
RETENTION_DRY_RUN=ON

# Observability / metrics / health breakdown
OBS_LATENCY_BUDGET_AUTH_LOGIN_MS=800
OBS_LATENCY_BUDGET_DASHBOARD_SUMMARY_MS=1200
OBS_LATENCY_BUDGET_MEDIA_UPLOAD_MS=1500
OBS_LATENCY_BUDGET_INTAKE_INGEST_MS=800
OBS_LATENCY_BUDGET_RECONCILE_REFRESH_MS=1500
OBS_LATENCY_BUDGET_INCIDENT_RESOLVE_MS=1200
OBS_LATENCY_BUDGET_AUDIT_LIST_MS=800
OBS_LATENCY_BUDGET_HEALTH_BREAKDOWN_MS=500
OBS_LATENCY_BUDGET_HEALTH_READY_MS=500
OBS_BACKGROUND_JOB_MAX_AGE_MINUTES=1440
OBS_RETENTION_JOB_MAX_AGE_MINUTES=1440
OBS_RUNTIME_DIR=.runtime
OBS_SECRET_REJECT_SPIKE_THRESHOLD=5
SMOKE_CORRELATION_ID=

# Backup / restore / disaster drill
BACKUP_ROOT_DIR=.backups
BACKUP_RETENTION_DEMO_DAYS=7
BACKUP_RETENTION_RC_DAYS=14
BACKUP_RPO_TARGET_MINUTES=60
BACKUP_RTO_TARGET_MINUTES=15
MYSQLDUMP_BIN=mysqldump
MYSQL_BIN=mysql
BACKUP_LOCAL_ARTIFACT_PATHS=uploads/gate-media,.runtime/observability
BACKUP_RESTORE_SOURCE=
RESTORE_VERIFY_CORRELATION_ID=

# Final RC gate / clean machine verification
RC_LABEL=backend-rc1
RC_CLEAN_MACHINE_PROFILE=DEMO
RC_REPEAT_SMOKE_RUNS=3
RC_EVIDENCE_ROOT_DIR=release-evidence/backend-rc1
RC_SKIP_TYPECHECK=OFF
RC_VERIFY_DEPLOYMENT_BEFORE_GATE=ON

# Pilot gate / release hardening
PILOT_LABEL=backend-pilot-ready
PILOT_EVIDENCE_ROOT_DIR=release-evidence/backend-pilot
PILOT_SKIP_TYPECHECK=OFF
PILOT_VERIFY_DEPLOYMENT_BEFORE_GATE=ON