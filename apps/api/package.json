    "compose:down": "docker compose -f ../../infra/docker/docker-compose.local.yml down",
    "verify:deployment": "tsx src/scripts/deployment-verify.ts",
    "secrets:check": "tsx src/scripts/secrets-check.ts",
    "bootstrap:local": "tsx src/scripts/deployment-bootstrap.ts --profile local-dev --compose-up",
    "bootstrap:demo": "tsx src/scripts/deployment-bootstrap.ts --profile demo --compose-up",
