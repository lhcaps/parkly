    "e2e:full": "pnpm -s e2e && pnpm -s tariff:audit && pnpm -s shift:close:smoke",
    "db:repair": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf repair",
    "flyway:conf": "tsx scripts/gen-flyway-conf.ts",
    "dev": "tsx src/server/index.ts",
    "worker:dev": "tsx src/worker/index.ts",
    "worker:ghost-purge": "tsx src/worker/jobs/ghost-presence-purge.worker.ts",
    "platform:up": "docker compose -f ../../infra/docker/docker-compose.platform.yml up -d",
    "platform:down": "docker compose -f ../../infra/docker/docker-compose.platform.yml down",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:vitest": "vitest run",
