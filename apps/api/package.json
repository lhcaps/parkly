    "backup:create": "tsx src/scripts/backup-create.ts",
    "backup:demo": "tsx src/scripts/backup-create.ts --profile demo",
    "backup:rc": "tsx src/scripts/backup-create.ts --profile release-candidate",
    "restore:apply": "tsx src/scripts/restore-apply.ts",
    "restore:verify": "tsx src/scripts/restore-verify.ts",
    "drill:disaster": "tsx src/scripts/disaster-drill.ts",
    "drill:disaster:demo": "tsx src/scripts/disaster-drill.ts --profile demo",
    "test:pr30": "node --import tsx --test src/tests/pr30-backup-restore.test.ts",
    "rc1:fixtures:check": "tsx src/scripts/rc1-fixture-check.ts",
