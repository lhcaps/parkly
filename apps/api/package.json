{
  "name": "@parkly/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "db:migrate": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf migrate",
    "db:info": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf info",
    "db:validate": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf validate",
    "prisma:pull": "prisma db pull && prisma generate",
    "db:seed:min": "tsx src/scripts/seed-min.ts",
    "db:seed:big": "tsx src/scripts/seed-big.ts",
    "db:seed:reset": "tsx src/scripts/seed-reset.ts",
    "db:grant:app": "tsx src/scripts/apply-grants-parking-app.ts",
    "db:grant:app:strict": "cross-env DB_GRANT_STRICT=ON tsx src/scripts/apply-grants-parking-app.ts",
    "outbox:drain": "tsx src/scripts/drain-outbox.ts",
    "outbox:requeue": "tsx src/scripts/requeue-outbox.ts",
    "test:gate-event": "tsx src/scripts/test-gate-event.ts",
    "demo:close-shift": "tsx src/scripts/close-shift-demo.ts",
    "shift:close:smoke": "tsx src/scripts/close-shift-demo.ts",
    "demo:tariff-audit": "tsx src/scripts/tariff-audit-demo.ts",
    "tariff:audit": "tsx src/scripts/tariff-audit-demo.ts",
    "e2e": "pnpm -s db:info && pnpm -s db:migrate && pnpm -s db:validate && pnpm -s prisma:pull && pnpm -s db:grant:app && pnpm -s db:seed:min && pnpm -s test:gate-event && pnpm -s outbox:drain",
    "e2e:full": "pnpm -s e2e && pnpm -s demo:tariff-audit && pnpm -s demo:close-shift",
    "db:repair": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf repair",
    "flyway:conf": "tsx scripts/gen-flyway-conf.ts",
    "dev": "tsx src/server/index.ts",
    "worker:dev": "tsx src/worker/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:whoami:app": "tsx src/scripts/db-whoami-app.ts",
    "prisma:generate": "prisma generate",
    "predev": "pnpm -s prisma:generate",
    "preworker:dev": "pnpm -s prisma:generate",
    "test:pr02": "node --import tsx --test src/tests/pr02-shared-plate-core.test.ts",
    "test:pr04": "node --import tsx --test src/tests/pr04-capture-auth-idempotency.test.ts",
    "test:pr06": "node --import tsx --test src/tests/pr06-decision-engine.test.ts"
  },
  "dependencies": {
    "@parkly/contracts": "workspace:*",
    "@parkly/gate-core": "workspace:*",
    "@prisma/adapter-mariadb": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.1.0",
    "mariadb": "^3.5.1",
    "mongodb": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.8.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@prisma/config": "^7.4.1",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^5.1.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.3.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "cross-env": "^7.0.3",
    "prisma": "^7.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
