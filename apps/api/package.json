{
  "name": "@parkly/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "db:migrate": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf migrate",
    "db:info": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf info",
    "db:validate": "pnpm -s flyway:conf && flyway -configFiles=db/flyway.conf validate",
    "prisma:pull": "prisma db pull && prisma generate",
    "db:seed:min": "tsx src/scripts/seed-min.ts",
    "db:seed:big": "tsx src/scripts/seed-big.ts",
    "db:seed:reset": "tsx src/scripts/seed-reset.ts",
    "db:seed:enterprise": "tsx prisma/seed-enterprise.ts",
    "db:grant:app": "tsx src/scripts/apply-grants-parking-app.ts",
    "db:grant:app:strict": "cross-env DB_GRANT_STRICT=ON tsx src/scripts/apply-grants-parking-app.ts",
    "outbox:drain": "tsx src/scripts/drain-outbox.ts",
    "outbox:requeue": "tsx src/scripts/requeue-outbox.ts",
