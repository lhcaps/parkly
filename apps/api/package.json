    "reset:local": "tsx src/scripts/deployment-reset.ts --profile local-dev",
    "reset:demo": "tsx src/scripts/deployment-reset.ts --profile demo",
    "reset:rc": "tsx src/scripts/deployment-reset.ts --profile release-candidate",
    "smoke:local": "tsx src/scripts/deployment-smoke.ts --profile local-dev",
