    "test:pr26": "node --import tsx --test src/tests/pr26-security-layer2.test.ts",
    "test:pr27": "node --import tsx --test src/tests/pr27-observability.test.ts",
    "test:rc1": "node --import tsx --test src/tests/smoke/rc1-release-consolidation.test.ts",
