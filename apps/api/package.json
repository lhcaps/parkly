    "test:pr34:metrics": "node --import tsx --test src/tests/pr34-secret-safety-observability.test.ts",
    "test:pr34:source": "node --import tsx --test src/tests/pr34-source-regression.test.ts",
    "test:pr34": "pnpm -s test:pr34:metrics && pnpm -s test:pr34:source",
    "pilot:gate": "tsx src/scripts/pilot-gate.ts",
    "test:pr35:gate": "node --import tsx --test src/tests/pr35-pilot-gate.test.ts",
    "test:pr35:source": "node --import tsx --test src/tests/pr35-source-regression.test.ts",
    "test:pr35": "pnpm -s test:pr35:gate && pnpm -s test:pr35:source"
