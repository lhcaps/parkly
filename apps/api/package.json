    "test:pr32:rules": "node --import tsx --test src/tests/pr32-secret-hygiene-rules.test.ts",
    "test:pr32:cli": "node --import tsx --test src/tests/pr32-secrets-check-cli.test.ts",
    "test:pr32:verify": "node --import tsx --test src/tests/pr32-deployment-verify-secrets.test.ts",
    "test:pr32:source": "node --import tsx --test src/tests/pr32-source-regression.test.ts",
    "test:pr32": "pnpm -s test:pr32:rules && pnpm -s test:pr32:cli && pnpm -s test:pr32:verify && pnpm -s test:pr32:source",
    "secrets:rotation:check": "tsx src/scripts/secrets-rotation-check.ts",
    "test:pr33:rotation": "node --import tsx --test src/tests/pr33-secret-rotation.test.ts",
