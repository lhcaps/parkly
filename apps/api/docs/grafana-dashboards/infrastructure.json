      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(redis_latency_ms_bucket[5m])))",
          "legendFormat": "redis p95",
          "refId": "A"
        },
        {
          "expr": "sum(rate(redis_command_failures_total[5m]))",
          "legendFormat": "redis failures",
          "refId": "B"
        }
      ],
      "title": "Redis Latency and Failures",
      "type": "timeseries"
