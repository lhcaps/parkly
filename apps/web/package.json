    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^6.26.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
