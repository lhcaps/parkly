    "playwright:runtime:check": "node ./scripts/check-playwright-runtime.mjs",
    "playwright:runtime:install": "playwright install chromium",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "node ./scripts/run-playwright-e2e.mjs",
    "test:smoke:auth-routes": "vitest run src/app/__tests__/role-policy.test.ts src/features/auth/__tests__/auth-redirect.test.ts"
  },
