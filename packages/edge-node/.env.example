# Parkly Edge Node — Environment Variables
# Copy to .env and fill in production values

# ── Identity ─────────────────────────────────────────────────────────────────
EDGE_NODE_ID=edge-hcm01
EDGE_SITE_CODE=SITE_HCM_01

# ── Cloud API (Parkly Cloud endpoint) ──────────────────────────────────────
EDGE_CLOUD_API_URL=http://localhost:3000
EDGE_CLOUD_API_KEY=edge_dev_sync_key_change_in_production

# ── Sync ────────────────────────────────────────────────────────────────────
# How often (ms) to pull subscriptions + tariffs from cloud
EDGE_SYNC_INTERVAL_MS=300000   # 5 minutes

# ── Local SQLite DB ────────────────────────────────────────────────────────
EDGE_SQLITE_PATH=./parkly-edge.db

# ── HTTP Server ─────────────────────────────────────────────────────────────
EDGE_PORT=8080

# ── LAN Subnet (for device discovery) ───────────────────────────────────────
EDGE_LAN_SUBNET=192.168.1.0/24

# ── Hardware Endpoints ──────────────────────────────────────────────────────
# Barrier controller HTTP endpoint
EDGE_BARRIER_ENDPOINT=http://192.168.1.100:9090/command

# Ticket printer HTTP endpoint
EDGE_PRINTER_ENDPOINT=http://192.168.1.101:9091/print

# ── Operational Thresholds ─────────────────────────────────────────────────
# Minimum subscriptions before alerting
EDGE_MIN_HEALTHY_SUBSCRIPTIONS=5

# Offline session TTL (hours) — sessions older than this are auto-closed
EDGE_OFFLINE_SESSION_TTL_HOURS=24
